# ==============================================
# Yemen Student Union System - Environment Config
# ==============================================
# ⚠️ COPY this file to .env and fill in your real values
# ⚠️ NEVER commit .env to Git!

# Application
APP_NAME="Yemen Student Union"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=yemen_union_db
DB_USERNAME=root
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# JWT Configuration (Generate a random 64-char string!)
JWT_SECRET=GENERATE_A_RANDOM_64_CHARACTER_SECRET_KEY_HERE_USE_OPENSSL
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# CORS Configuration
CORS_ORIGIN=http://localhost:5176

# Wasender API
WASENDER_API_KEY=YOUR_WASENDER_API_KEY

# SMTP (Sending Emails)
MAIL_DRIVER=smtp
MAIL_HOST=smtp-mail.outlook.com
MAIL_PORT=587
MAIL_USERNAME=your-email@outlook.com
MAIL_PASSWORD=YOUR_EMAIL_APP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your-email@outlook.com
MAIL_FROM_NAME="${APP_NAME}"

# IMAP (Fetching Replies)
IMAP_HOST=outlook.office365.com:993/imap/ssl
IMAP_USERNAME=your-email@outlook.com
IMAP_PASSWORD=YOUR_EMAIL_APP_PASSWORD

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_OTP=3
RATE_LIMIT_API=60
