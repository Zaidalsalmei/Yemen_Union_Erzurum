{
    "openapi": "3.0.3",
    "info": {
        "title": "Yemen Student Union - Member API",
        "description": "API documentation for member-facing endpoints in the Yemen Student Union System",
        "version": "1.0.0",
        "contact": {
            "name": "Yemen Student Union",
            "email": "support@yemenunion.org"
        }
    },
    "servers": [
        {
            "url": "http://localhost/api",
            "description": "Local development server"
        },
        {
            "url": "https://api.yemenunion.org/api",
            "description": "Production server"
        }
    ],
    "tags": [
        {
            "name": "Dashboard",
            "description": "Member dashboard endpoints"
        },
        {
            "name": "Profile",
            "description": "Member profile management"
        },
        {
            "name": "Membership",
            "description": "Membership and subscription management"
        },
        {
            "name": "Activities",
            "description": "Activity registration and participation"
        },
        {
            "name": "Notifications",
            "description": "Member notifications"
        },
        {
            "name": "Posts",
            "description": "Posts and announcements"
        },
        {
            "name": "Support",
            "description": "Support tickets"
        },
        {
            "name": "Payments",
            "description": "Payment history and proofs"
        }
    ],
    "paths": {
        "/member/dashboard": {
            "get": {
                "tags": [
                    "Dashboard"
                ],
                "summary": "Get member dashboard data",
                "description": "Returns all data needed for the member home dashboard including KPIs, subscription, activities, posts, and notifications",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Dashboard data retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/DashboardResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/member/profile": {
            "put": {
                "tags": [
                    "Profile"
                ],
                "summary": "Update member profile",
                "description": "Update member profile information including photo",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/ProfileUpdateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProfileUpdateResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/ValidationError"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/member/payments/history": {
            "get": {
                "tags": [
                    "Payments"
                ],
                "summary": "Get payment history",
                "description": "Get member's payment history with pagination",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Payment history retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaymentHistoryResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/memberships/payment-proof": {
            "post": {
                "tags": [
                    "Payments"
                ],
                "summary": "Upload payment proof",
                "description": "Upload payment proof image for membership renewal",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/PaymentProofRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Payment proof uploaded successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PaymentProofResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/ValidationError"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/member/notifications": {
            "get": {
                "tags": [
                    "Notifications"
                ],
                "summary": "Get member notifications",
                "description": "Get member's notifications with pagination",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    },
                    {
                        "name": "unread_only",
                        "in": "query",
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notifications retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotificationsResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/member/posts": {
            "get": {
                "tags": [
                    "Posts"
                ],
                "summary": "Get member posts",
                "description": "Get posts visible to members with read tracking",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "category",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "all",
                                "announcement",
                                "event",
                                "financial_alert",
                                "general"
                            ],
                            "default": "all"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Posts retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PostsResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/support/tickets": {
            "post": {
                "tags": [
                    "Support"
                ],
                "summary": "Create support ticket",
                "description": "Create a new support ticket",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/SupportTicketRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Support ticket created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SupportTicketResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/ValidationError"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/activities/{id}/register": {
            "post": {
                "tags": [
                    "Activities"
                ],
                "summary": "Register for activity",
                "description": "Register the current member for an activity",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Registered successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ActivityRegistrationResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/ValidationError"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/activities/{id}/unregister": {
            "post": {
                "tags": [
                    "Activities"
                ],
                "summary": "Unregister from activity",
                "description": "Unregister the current member from an activity",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Unregistered successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/ValidationError"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/activities/{id}/checkin": {
            "post": {
                "tags": [
                    "Activities"
                ],
                "summary": "Check-in to activity",
                "description": "Check-in the current member to an activity (only on activity day)",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Checked-in successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ActivityCheckinResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/ValidationError"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        },
        "/auth/logout-all-devices": {
            "post": {
                "tags": [
                    "Profile"
                ],
                "summary": "Logout from all devices",
                "description": "Revoke all sessions except the current one",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logged out from all devices successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LogoutAllDevicesResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "schemas": {
            "DashboardResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "member": {
                                "$ref": "#/components/schemas/Member"
                            },
                            "kpis": {
                                "$ref": "#/components/schemas/KPIs"
                            },
                            "subscription": {
                                "$ref": "#/components/schemas/Subscription"
                            },
                            "upcomingActivities": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Activity"
                                }
                            },
                            "recentPosts": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Post"
                                }
                            },
                            "notifications": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Notification"
                                }
                            },
                            "isFirstLogin": {
                                "type": "boolean"
                            }
                        }
                    }
                }
            },
            "Member": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "full_name": {
                        "type": "string"
                    },
                    "phone_number": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "profile_photo": {
                        "type": "string"
                    },
                    "member_id": {
                        "type": "string"
                    },
                    "branch": {
                        "type": "string"
                    },
                    "join_date": {
                        "type": "string",
                        "format": "date"
                    },
                    "last_login_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "account_status": {
                        "type": "string",
                        "enum": [
                            "active",
                            "pending",
                            "suspended",
                            "banned"
                        ]
                    },
                    "city": {
                        "type": "string"
                    },
                    "university": {
                        "type": "string"
                    },
                    "faculty": {
                        "type": "string"
                    }
                }
            },
            "KPIs": {
                "type": "object",
                "properties": {
                    "subscription_status": {
                        "type": "string"
                    },
                    "subscription_expiry": {
                        "type": "string",
                        "format": "date"
                    },
                    "days_remaining": {
                        "type": "integer"
                    },
                    "upcoming_activities_count": {
                        "type": "integer"
                    },
                    "unread_notifications_count": {
                        "type": "integer"
                    },
                    "new_posts_count": {
                        "type": "integer"
                    },
                    "missing_documents_count": {
                        "type": "integer"
                    }
                }
            },
            "Subscription": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "status": {
                        "type": "string"
                    },
                    "start_date": {
                        "type": "string",
                        "format": "date"
                    },
                    "end_date": {
                        "type": "string",
                        "format": "date"
                    },
                    "package_name": {
                        "type": "string"
                    },
                    "amount": {
                        "type": "number"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "is_paid": {
                        "type": "boolean"
                    },
                    "days_until_expiry": {
                        "type": "integer"
                    }
                }
            },
            "Activity": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "title_ar": {
                        "type": "string"
                    },
                    "description_ar": {
                        "type": "string"
                    },
                    "activity_date": {
                        "type": "string",
                        "format": "date"
                    },
                    "start_time": {
                        "type": "string",
                        "format": "time"
                    },
                    "location_ar": {
                        "type": "string"
                    },
                    "max_participants": {
                        "type": "integer"
                    },
                    "participant_count": {
                        "type": "integer"
                    },
                    "registration_required": {
                        "type": "boolean"
                    },
                    "is_registered": {
                        "type": "boolean"
                    }
                }
            },
            "Post": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "title": {
                        "type": "string"
                    },
                    "excerpt": {
                        "type": "string"
                    },
                    "category": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "author_name": {
                        "type": "string"
                    },
                    "is_read": {
                        "type": "boolean"
                    }
                }
            },
            "Notification": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "info",
                            "warning",
                            "success",
                            "error"
                        ]
                    },
                    "title": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "action_url": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "ProfileUpdateRequest": {
                "type": "object",
                "properties": {
                    "full_name": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "city": {
                        "type": "string"
                    },
                    "university": {
                        "type": "string"
                    },
                    "faculty": {
                        "type": "string"
                    },
                    "profile_photo": {
                        "type": "string",
                        "format": "binary"
                    }
                },
                "required": [
                    "full_name",
                    "city"
                ]
            },
            "ProfileUpdateResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "user": {
                                "$ref": "#/components/schemas/Member"
                            }
                        }
                    }
                }
            },
            "PaymentHistoryResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "payments": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "integer"
                                        },
                                        "amount": {
                                            "type": "number"
                                        },
                                        "currency": {
                                            "type": "string"
                                        },
                                        "payment_date": {
                                            "type": "string",
                                            "format": "date"
                                        },
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "pagination": {
                                "$ref": "#/components/schemas/Pagination"
                            }
                        }
                    }
                }
            },
            "PaymentProofRequest": {
                "type": "object",
                "properties": {
                    "membership_id": {
                        "type": "integer"
                    },
                    "proof_image": {
                        "type": "string",
                        "format": "binary"
                    },
                    "notes": {
                        "type": "string"
                    }
                },
                "required": [
                    "membership_id",
                    "proof_image"
                ]
            },
            "PaymentProofResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "payment_proof": {
                                "type": "object",
                                "properties": {
                                    "id": {
                                        "type": "integer"
                                    },
                                    "status": {
                                        "type": "string"
                                    },
                                    "uploaded_at": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "NotificationsResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "notifications": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Notification"
                                }
                            },
                            "unread_count": {
                                "type": "integer"
                            },
                            "pagination": {
                                "$ref": "#/components/schemas/Pagination"
                            }
                        }
                    }
                }
            },
            "PostsResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "posts": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/Post"
                                }
                            },
                            "new_posts_count": {
                                "type": "integer"
                            },
                            "pagination": {
                                "$ref": "#/components/schemas/Pagination"
                            }
                        }
                    }
                }
            },
            "SupportTicketRequest": {
                "type": "object",
                "properties": {
                    "subject": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "attachment": {
                        "type": "string",
                        "format": "binary"
                    }
                },
                "required": [
                    "subject",
                    "message"
                ]
            },
            "SupportTicketResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "ticket": {
                                "type": "object",
                                "properties": {
                                    "id": {
                                        "type": "integer"
                                    },
                                    "ticket_number": {
                                        "type": "string"
                                    },
                                    "status": {
                                        "type": "string"
                                    },
                                    "created_at": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "ActivityRegistrationResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "registration": {
                                "type": "object",
                                "properties": {
                                    "activity_id": {
                                        "type": "integer"
                                    },
                                    "user_id": {
                                        "type": "integer"
                                    },
                                    "registration_date": {
                                        "type": "string",
                                        "format": "date-time"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "ActivityCheckinResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "data": {
                        "type": "object",
                        "properties": {
                            "activity_id": {
                                "type": "integer"
                            },
                            "user_id": {
                                "type": "integer"
                            },
                            "checked_in_at": {
                                "type": "string",
                                "format": "date-time"
                            },
                            "attendance_status": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "LogoutAllDevicesResponse": {
                "type": "object",
                "properties": {
                    "success": {
